// For format details, see https://aka.ms/devcontainer.json. For config options, see the README at:
// https://github.com/sarisia/mikanos-devcontainer
{
	"name": "MikanOS",
	"build": {
		"dockerfile": "Dockerfile",
		// Choose variant: latest, vnc
		// Set `vnc` to spin up noVNC services. Useful in GitHub Codespaces.
		"args": { "VARIANT": "vnc" }
	},

	// Claude Code CLI (Node.js is installed automatically by the feature).
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
	},

	// =======================================================================
	// noVNC enabled (variant: vnc). Open the forwarded port 6080 in a browser
	// to see QEMU's screen. Works locally and in GitHub Codespaces.
	// =======================================================================

	"forwardPorts": [6080],
	"overrideCommand": false,
	"containerEnv": {
		// Port for noVNC Web Client & WebSocket
		"NOVNC_PORT": "6080",
		// VNC port QEMU listens. Default to 5900 + <display number>
		// If you run QEMU with "-vnc :1", then VNC_PORT should be 5901.
		"VNC_PORT": "5900",
		// QEMU launch options. Used in `run_image.sh`
		"QEMU_OPTS": "-vnc :0"
	},


	// =======================================================================
	// Uncomment to enable WSLg integration
	// =======================================================================

	// "mounts": [
	// 	"type=bind,source=/tmp/.X11-unix,target=/tmp/.X11-unix"
	// ],
	// "containerEnv": {
	// 	"DISPLAY": "${localEnv:DISPLAY}"
	// },


	// Set *default* container specific settings.json values on container create.
	"settings": { 
		"terminal.integrated.shell.linux": "/bin/bash"
	},

	// Add the IDs of extensions you want installed when the container is created.
	"extensions": [
		"ms-vscode.cpptools"
	],

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "uname -a",

	// Comment out connect as root instead. More info: https://aka.ms/vscode-remote/containers/non-root.
	"remoteUser": "vscode",

	"runArgs": [
		"--privileged",
		"--disable-content-trust=true"
	]
}
